# API Keys (set on Vercel Dashboard → Project Settings → Environment Variables)
OPENCODE_ZEN_API_KEY=sk-...  # OpenCode Zen API key (https://opencode.ai/zen)
# Free models used by default: deepseek-v4-flash-free, mimo-v2.5-free
OPENAI_API_KEY=sk-...          # Fallback: OpenAI key
ADLIB_MODEL=gpt-4o-mini       # Optional: model override (default: gpt-4o-mini)

# No other config needed.
